# Python相关忽略规则
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pdb
*.egg
*.egg-info/
dist/
build/
*.so
archive.zip
# test
test/
logs/

# Jupyter Notebook
.ipynb_checkpoints

# 数据文件
data/
data/MNIST/raw/
!data/MNIST/raw/*.gz

# 模型文件
*.pth

# 日志文件
*.log

# 环境配置文件
.env
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# IDE相关文件
.vscode/
.idea/
*.swp
*.swo

# Matplotlib缓存
.matplotlib/

# JSON结果文件
trigger_results.json

# 压缩文件
*.zip
*.tar.gz

# 实验结果目录：忽略数据产物，但保留结果图
results/**
!results/**/
!results/**/*.png
!results/**/*.jpg
!results/**/*.jpeg
!results/**/*.svg
!results/**/*.pdf

Effcientnet/results/**
!Effcientnet/results/**/
!Effcientnet/results/**/*.png
!Effcientnet/results/**/*.jpg
!Effcientnet/results/**/*.jpeg
!Effcientnet/results/**/*.svg
!Effcientnet/results/**/*.pdf
